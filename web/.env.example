# 後端 API 基底 URL（dev proxy 會將 /api/* 轉發至此）
VITE_API_BASE_URL=http://localhost:5000

# Azure AD / Entra ID（issue #34 [2.1.2] 將會啟用）
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# 預設 API 路徑前綴
VITE_API_PREFIX=/api

# RBAC mock 模式（true = 啟用假資料，無需後端）。生產環境請設為 false
VITE_USE_MOCK_RBAC=false
