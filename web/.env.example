# 後端 API 基底 URL（dev proxy 會將 /api/* 轉發至此）
VITE_API_BASE_URL=http://localhost:5000

# 預設 API 路徑前綴
VITE_API_PREFIX=/api

# Azure AD / Entra ID 設定（issue #34 [2.1.2] 已啟用）
# 在 Azure portal「應用程式註冊」取得這些值（issue #2 [2.1.1] docs/auth.md §2 詳列步驟）
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# 後端 API scope（issue #2 [2.1.1] 在 Azure portal「公開 API」設定的 scope）
# 格式：api://<API_CLIENT_ID>/access_as_user
# 留空時 fallback 為 User.Read（僅供 dev 試 SSO，無法呼叫 IsoDocs API）
VITE_AZURE_API_SCOPE=

# RBAC mock 模式（issue #8 [2.2.2] 加入）
# true  → 描截 /roles 與 /users 請求，使用 mockRoles.ts 裡的假資料
# false → 送到真實後端（要等 issue #6 [2.2.1] 落地才能使用）
# dev 預設為 true；production build 請設 false
VITE_USE_MOCK_RBAC=true

# 自訂欄位 mock 模式（issue #11 [3.1.2] 加入）
# true  → 描截 /field-definitions 請求，使用 mockFieldDefinitions.ts 裡的假資料
# false → 送到真實後端（要等 issue #7 [3.1.1] 落地才能使用）
# dev 預設為 true；production build 請設 false
VITE_USE_MOCK_FIELDS=true
